---
// Minimum mode — no JS, no CSS, no decorative UI
import { resolveLocation, getWeather } from '../../lib/routes';
import { formatMin } from '../../lib/formatter';
import { startTimer } from '../../lib/metrics';

const totalTimer = startTimer();
const url = new URL(Astro.request.url);
const location = await resolveLocation(url);

if (location.error) {
  return new Response(`Error: ${location.error}\n\nUsage: /weather/min?city=Munich or /weather/min?lat=48.14&lon=11.58`, {
    status: 400,
    headers: { 'Content-Type': 'text/plain; charset=utf-8', 'Cache-Control': 'no-store' },
  });
}

try {
  const { data, cacheHit } = await getWeather(location.lat, location.lon);

  // Override location with resolved name if geocoded
  if (location.name) {
    data.location = location.name;
  }

  const totalMs = totalTimer();

  const text = formatMin(data);
  const payloadBytes = new TextEncoder().encode(text).length;

  return new Response(text, {
    status: 200,
    headers: {
      'Content-Type': 'text/plain; charset=utf-8',
      'X-Payload-Size': payloadBytes.toString(),
      'X-Cache-Status': cacheHit ? 'hit' : 'miss',
      'X-Render-Time': `${totalMs}ms`,
      'Cache-Control': 'public, max-age=300',
    },
  });
} catch (err: any) {
  return new Response(`Weather service unavailable: ${err.message}`, {
    status: 502,
    headers: { 'Content-Type': 'text/plain; charset=utf-8', 'Cache-Control': 'no-store' },
  });
}
---
