---
// Normal mode — tiny inline CSS, ASCII art, payload metrics
import { resolveLocation, getWeather } from '../../lib/routes';
import { formatNormal } from '../../lib/formatter';
import { startTimer } from '../../lib/metrics';

const totalTimer = startTimer();
const url = new URL(Astro.request.url);
const location = await resolveLocation(url);

if (location.error) {
  return new Response(`<!DOCTYPE html><html><body><pre>Error: ${location.error}\n\nUsage: /weather?city=Munich or /weather?lat=48.14&lon=11.58</pre></body></html>`, {
    status: 400,
    headers: { 'Content-Type': 'text/html; charset=utf-8', 'Cache-Control': 'no-store' },
  });
}

try {
  const renderTimer = startTimer();
  const { data, cacheHit } = await getWeather(location.lat, location.lon);

  // Override location with resolved name if geocoded
  if (location.name) {
    data.location = location.name;
  }

  const weatherApiMs = data.apiLatencyMs;
  const renderMs = renderTimer();
  const totalMs = totalTimer();

  let html = formatNormal(data, { totalMs, weatherApiMs, cacheHit, renderMs });

  // Inject "set as my location" button before </body>
  const locationName = location.name || `${location.lat},${location.lon}`;
  const saveSnippet = `<div style="margin-top:.5rem;font-size:11px"><button id="set-home" style="display:none;background:none;border:none;color:#6cf;font-family:monospace;font-size:11px;cursor:pointer;padding:0">📌 set as my location</button> <a href="/utils" style="color:#666;text-decoration:none;font-size:11px">utils</a></div><script>document.getElementById('set-home').style.display='';document.getElementById('set-home').onclick=function(){localStorage.setItem('weather-lite:home',JSON.stringify({lat:${location.lat},lon:${location.lon},name:'${locationName.replace(/'/g, "\\'")}'}}));this.textContent='✓ saved';};</script>`;
  html = html.replace('</body>', saveSnippet + '</body>');

  const payloadBytes = new TextEncoder().encode(html).length;

  return new Response(html, {
    status: 200,
    headers: {
      'Content-Type': 'text/html; charset=utf-8',
      'X-Payload-Size': payloadBytes.toString(),
      'X-Cache-Status': cacheHit ? 'hit' : 'miss',
      'X-Render-Time': `${totalMs}ms`,
      'Cache-Control': 'public, max-age=300',
    },
  });
} catch (err: any) {
  return new Response(`<!DOCTYPE html><html><body><pre>Weather service unavailable: ${err.message}</pre></body></html>`, {
    status: 502,
    headers: { 'Content-Type': 'text/html; charset=utf-8', 'Cache-Control': 'no-store' },
  });
}
---
